{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://magicgourd.local/loop/result.schema.json",
  "title": "MagicGourd Loop Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "status",
    "summary",
    "checks_run",
    "blocker",
    "next_hint"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "blocked",
        "needs_more_work"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "checks_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocker": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_hint": {
      "type": "string",
      "minLength": 1
    }
  }
}

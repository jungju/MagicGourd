          <string name="Source"><![CDATA[local moveSpeedValues = { 16, 18, 20, 22 }
local attackSpeedValues = { 0.75, 0.6, 0.45, 0.3 }
local seedGainValues = { 1, 2, 3, 4 }

local config = {

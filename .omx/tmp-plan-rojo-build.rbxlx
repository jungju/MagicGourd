      <Item class="ModuleScript" referent="6">
        <Properties>
          <string name="Name">ArcadeRuntime</string>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local ArcadeConfig = require(Shared:WaitForChild("ArcadeConfig"))
local ArcadeWorld = require(script.Parent:WaitForChild("ArcadeWorld"))
local GoblinService = require(script.Parent:WaitForChild("GoblinService"))
local PlayerStateService = require(script.Parent:WaitForChild("PlayerStateService"))
local PumpkinService = require(script.Parent:WaitForChild("PumpkinService"))
local SwallowService = require(script.Parent:WaitForChild("SwallowService"))
local UpgradeService = require(script.Parent:WaitForChild("UpgradeService"))

local ArcadeRuntime = {}

local function ensureRemotes(sharedFolder)
	local remotes = {}

	-- Only ensure the arcade loop remotes exist.
	-- Do not delete unrelated Shared remotes here: Studio helpers, migration shims,
	-- or parallel experiments may coexist during refinement passes.
	for key, remoteName in pairs(ArcadeConfig.RemoteNames) do
		local remote = sharedFolder:FindFirstChild(remoteName)
		if not remote then
			remote = Instance.new("RemoteEvent")
			remote.Name = remoteName
			remote.Parent = sharedFolder
		end
		remotes[key] = remote
	end

	return remotes
end

function ArcadeRuntime.start()
	print("MagicGourd arcade server started")

	local remotes = ensureRemotes(Shared)
	local world = ArcadeWorld.build(ArcadeConfig)
	local playerState = PlayerStateService.new(ArcadeConfig, world)
	local pumpkinService = PumpkinService.new(ArcadeConfig, world, playerState)
	local swallowService = SwallowService.new(ArcadeConfig, world, playerState)
	local upgradeService = UpgradeService.new(ArcadeConfig, world, playerState)
	local goblinService = GoblinService.new(ArcadeConfig, world, playerState)

	playerState:registerCleanup(function(player)
		pumpkinService:destroyPlayerPumpkins(player)
	end)

	playerState:start()
	upgradeService:start(remotes)
	swallowService:start(remotes)
	pumpkinService:start(remotes)
	goblinService:start(remotes)
end

return ArcadeRuntime
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="7">
        <Properties>
          <string name="Name">ArcadeWorld</string>
          <string name="Source"><![CDATA[local Workspace = game:GetService("Workspace")

local ArcadeWorld = {}

local function createFolder(parent, name)
	local folder = Instance.new("Folder")
	folder.Name = name
	folder.Parent = parent
	return folder
end

local function createPart(parent, name, size, cframe, color, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.CFrame = cframe
	part.Anchored = true
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.Color = color
	part.Material = material
	part.Parent = parent
	return part
end

local function createPrompt(parent, actionText, objectText, maxDistance)
	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText = actionText
	prompt.ObjectText = objectText
	prompt.MaxActivationDistance = maxDistance or 12
	prompt.RequiresLineOfSight = false
	prompt.HoldDuration = 0
	prompt.Exclusivity = Enum.ProximityPromptExclusivity.OnePerButton
	prompt.Parent = parent
	return prompt
end

local BILLBOARD_PRESETS = {
	Loop = {
		size = Vector2.new(236, 86),
		offset = Vector3.new(0, 5.5, 0),
		alwaysOnTop = true,
		backgroundTransparency = 0.16,
		strokeThickness = 2.4,
		titleHeight = 24,
		titleSize = 20,
		titleTransparency = 0,
		bodyY = 34,
		bodyTextSize = 14,
		bodyColor = Color3.fromRGB(234, 228, 216),
		bodyTransparency = 0.02,
		strokeTransparency = 0.05,
	},
	Zone = {
		size = Vector2.new(204, 72),
		offset = Vector3.new(0, 5.1, 0),
		alwaysOnTop = true,
		backgroundTransparency = 0.31,
		strokeThickness = 1.8,
		titleHeight = 20,
		titleSize = 17,
		titleTransparency = 0.03,
		bodyY = 29,
		bodyTextSize = 11,
		bodyColor = Color3.fromRGB(221, 216, 204),
		bodyTransparency = 0.16,
		strokeTransparency = 0.1,
	},
	Lane = {
		size = Vector2.new(194, 68),
		offset = Vector3.new(0, 5, 0),
		alwaysOnTop = true,
		backgroundTransparency = 0.38,
		strokeThickness = 1.55,
		titleHeight = 19,
		titleSize = 16,
		titleTransparency = 0.06,
		bodyY = 28,
		bodyTextSize = 11,
		bodyColor = Color3.fromRGB(216, 209, 197),
		bodyTransparency = 0.2,
		strokeTransparency = 0.14,
	},
	Plaza = {
		size = Vector2.new(170, 54),
		offset = Vector3.new(0, 4.35, 0),
		alwaysOnTop = false,
		backgroundTransparency = 0.54,
		strokeThickness = 1.15,
		titleHeight = 18,
		titleSize = 14,
		titleTransparency = 0.12,
		bodyY = 25,
		bodyTextSize = 10,
		bodyColor = Color3.fromRGB(205, 199, 190),
		bodyTransparency = 0.34,
		strokeTransparency = 0.4,
	},
}

local function attachBillboard(part, title, body, color, presetName)
	local preset = BILLBOARD_PRESETS[presetName] or BILLBOARD_PRESETS.Zone

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "Sign"
	billboard.Size = UDim2.fromOffset(preset.size.X, preset.size.Y)
	billboard.StudsOffsetWorldSpace = preset.offset
	billboard.AlwaysOnTop = preset.alwaysOnTop
	billboard.Adornee = part
	billboard.Parent = part

	local frame = Instance.new("Frame")
	frame.Size = UDim2.fromScale(1, 1)
	frame.BackgroundColor3 = Color3.fromRGB(20, 18, 16)
	frame.BackgroundTransparency = preset.backgroundTransparency
	frame.BorderSizePixel = 0
	frame.Parent = billboard

	local padding = Instance.new("UIPadding")
	padding.PaddingTop = UDim.new(0, 6)
	padding.PaddingBottom = UDim.new(0, 8)
	padding.PaddingLeft = UDim.new(0, 10)
	padding.PaddingRight = UDim.new(0, 10)
	padding.Parent = frame

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = frame

	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = preset.strokeThickness
	stroke.Transparency = preset.strokeTransparency or 0.05
	stroke.Parent = frame

	local titleLabel = Instance.new("TextLabel")
	titleLabel.BackgroundTransparency = 1
	titleLabel.Position = UDim2.fromOffset(0, 0)
	titleLabel.Size = UDim2.new(1, 0, 0, preset.titleHeight)
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.Text = title
	titleLabel.TextColor3 = Color3.fromRGB(248, 240, 218)
	titleLabel.TextSize = preset.titleSize
	titleLabel.TextTransparency = preset.titleTransparency or 0
	titleLabel.TextWrapped = false
	titleLabel.TextXAlignment = Enum.TextXAlignment.Center
	titleLabel.TextYAlignment = Enum.TextYAlignment.Center
	titleLabel.Parent = frame

	if body and body ~= "" then
		local bodyLabel = Instance.new("TextLabel")
		bodyLabel.BackgroundTransparency = 1
		bodyLabel.Position = UDim2.fromOffset(0, preset.bodyY - 6)
		bodyLabel.Size = UDim2.new(1, 0, 1, -(preset.bodyY - 2))
		bodyLabel.Font = Enum.Font.Gotham
		bodyLabel.Text = body
		bodyLabel.TextWrapped = true
		bodyLabel.TextColor3 = preset.bodyColor
		bodyLabel.TextSize = preset.bodyTextSize
		bodyLabel.TextTransparency = preset.bodyTransparency
		bodyLabel.TextXAlignment = Enum.TextXAlignment.Center
		bodyLabel.TextYAlignment = Enum.TextYAlignment.Top
		bodyLabel.Parent = frame
	end
end

local function createLantern(parent, name, position, color)
	createPart(parent, name .. "Post", Vector3.new(0.45, 6, 0.45), CFrame.new(position + Vector3.new(0, 3, 0)), Color3.fromRGB(77, 60, 46), Enum.Material.Wood)

	local lightPart = createPart(parent, name .. "Lamp", Vector3.new(1.2, 1.2, 1.2), CFrame.new(position + Vector3.new(0, 6.3, 0)), color, Enum.Material.Neon)
	lightPart.Shape = Enum.PartType.Ball
	lightPart.CanCollide = false

	local pointLight = Instance.new("PointLight")
	pointLight.Brightness = 1.2
	pointLight.Range = 18
	pointLight.Color = color
	pointLight.Parent = lightPart
end

local function createSignPost(parent, name, position, title, body, color)
	local post = createPart(parent, name .. "Post", Vector3.new(0.5, 4.2, 0.5), CFrame.new(position + Vector3.new(0, 2.1, 0)), Color3.fromRGB(82, 62, 44), Enum.Material.Wood)
	post.CanCollide = false

	local sign = createPart(parent, name .. "Board", Vector3.new(6.5, 3.2, 0.4), CFrame.new(position + Vector3.new(0, 4.4, 0)), Color3.fromRGB(54, 40, 31), Enum.Material.WoodPlanks)
	sign.CanCollide = false
	attachBillboard(sign, title, body, color, "Lane")
	return sign
end

function ArcadeWorld.build(config)
	local map = Workspace:FindFirstChild("Map")
	if not map then
		map = Instance.new("Folder")
		map.Name = "Map"
		map.Parent = Workspace
	end

	local runtime = map:FindFirstChild("Runtime")
	if not runtime then
		runtime = Instance.new("Folder")
		runtime.Name = "Runtime"
		runtime.Parent = map
	end

	runtime:ClearAllChildren()

	local root = createFolder(runtime, "ArcadeLoop")
	local staticFolder = createFolder(root, "Static")
	local swallowFolder = createFolder(root, "Swallows")
	local pumpkinFolder = createFolder(root, "Pumpkins")
	local goblinFolder = createFolder(root, "Goblins")

	for zoneName, zone in pairs(config.World.Zones) do
		local pad = createPart(
			staticFolder,
			zoneName .. "Pad",
			zone.size,
			CFrame.new(zone.center),
			zone.color,
			zone.material
		)
		attachBillboard(
			pad,
			zone.title,
			zone.body,
			zoneName == "NolbuDanger" and Color3.fromRGB(224, 126, 109) or Color3.fromRGB(229, 196, 124),
			"Zone"
		)
	end

	for _, path in ipairs(config.World.Paths) do
		createPart(staticFolder, path.name, path.size, path.cframe, path.color, Enum.Material.Cobblestone)
	end

	for index, position in ipairs(config.World.WorkLanePosts or {}) do
		createLantern(staticFolder, string.format("WorkLaneLantern%d", index), position, Color3.fromRGB(234, 183, 96))
	end

	for _, landmark in ipairs(config.World.LaneLandmarks or {}) do
		createSignPost(staticFolder, landmark.name, landmark.position, landmark.title, landmark.body, landmark.color)
	end

	local spawn = Instance.new("SpawnLocation")
	spawn.Name = "ArcadeSpawn"
	spawn.Size = Vector3.new(10, 1, 10)
	spawn.CFrame = CFrame.new(config.World.SpawnPoint)
	spawn.Color = Color3.fromRGB(218, 190, 120)
	spawn.Material = Enum.Material.SmoothPlastic
	spawn.Anchored = true
	spawn.Neutral = true
	spawn.Transparency = 0.2
	spawn.CanCollide = true
	spawn.Parent = staticFolder

	attachBillboard(spawn, "Arcade Loop", "Heal -> Plant -> Break -> Buy.", Color3.fromRGB(240, 205, 117), "Loop")

	local statue = createPart(staticFolder, "PumpkinStatue", Vector3.new(4, 4, 4), CFrame.new(config.World.SpawnPoint + Vector3.new(0, 3.2, -8)), Color3.fromRGB(211, 133, 46), Enum.Material.SmoothPlastic)
	statue.Shape = Enum.PartType.Ball

	local stem = createPart(staticFolder, "PumpkinStatueStem", Vector3.new(0.6, 1.2, 0.6), statue.CFrame + Vector3.new(0, 2.3, 0), Color3.fromRGB(80, 120, 68), Enum.Material.Wood)
	stem.CanCollide = false

	local upgradePromptDistance = (config.Upgrades and config.Upgrades.PromptDistance) or 9
	local upgradePrompts = {}
	for upgradeId, padDef in pairs(config.World.UpgradePads) do
		local pad = createPart(
			staticFolder,
			upgradeId .. "Pad",
			Vector3.new(8, 1.2, 8),
			CFrame.new(padDef.position),
			padDef.color,
			Enum.Material.WoodPlanks
		)
		pad:SetAttribute(config.Attributes.Interaction.UpgradeId, upgradeId)
		attachBillboard(pad, padDef.displayName, padDef.body, padDef.color, "Plaza")
		upgradePrompts[upgradeId] = createPrompt(pad, "Buy", padDef.displayName, upgradePromptDistance)
	end

	for index, point in ipairs(config.World.DangerRockPositions or config.World.GoblinSpawnPoints) do
		createPart(staticFolder, "DangerRock" .. index, Vector3.new(5, 3, 4), CFrame.new(point + Vector3.new(0, 0.9, 0)), Color3.fromRGB(71, 63, 67), Enum.Material.Rock)
	end

	createLantern(staticFolder, "VillageLanternA", Vector3.new(-92, 0.5, 22), Color3.fromRGB(240, 211, 125))
	createLantern(staticFolder, "VillageLanternB", Vector3.new(-54, 0.5, 30), Color3.fromRGB(240, 211, 125))
	createLantern(staticFolder, "DangerLanternA", Vector3.new(58, 0.5, 12), Color3.fromRGB(236, 144, 104))
	createLantern(staticFolder, "DangerLanternB", Vector3.new(88, 0.5, 34), Color3.fromRGB(236, 144, 104))

	return {
		root = root,
		folders = {
			static = staticFolder,
			swallows = swallowFolder,
			pumpkins = pumpkinFolder,
			goblins = goblinFolder,
		},
		spawnLocation = spawn,
		spawnCFrame = spawn.CFrame + Vector3.new(0, 4, 0),
		swallowSpawnPoints = config.World.SwallowSpawnPoints,
		goblinSpawnPoints = config.World.GoblinSpawnPoints,
		upgradePrompts = upgradePrompts,
	}
end

return ArcadeWorld
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="8">
        <Properties>
          <string name="Name">GoblinService</string>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")

local GoblinService = {}

local function getDangerBounds(dangerZone, padding, invertPadding)
	if type(dangerZone) ~= "table" then
		return nil
	end

	local center = dangerZone.center
	local size = dangerZone.size
	if typeof(center) ~= "Vector3" or typeof(size) ~= "Vector3" then
		return nil
	end

	local halfSize = size * 0.5
	local frontPadding = 0
	local backPadding = 0
	local sidePadding = 0

	if type(padding) == "table" then
		frontPadding = math.max(tonumber(padding.Front) or 0, 0)
		backPadding = math.max(tonumber(padding.Back) or 0, 0)
		sidePadding = math.max(tonumber(padding.Side) or 0, 0)
	else
		local uniformPadding = math.max(tonumber(padding) or 0, 0)
		frontPadding = uniformPadding
		backPadding = uniformPadding
		sidePadding = uniformPadding
	end

	local direction = invertPadding and 1 or -1
	local minX = center.X - halfSize.X + (frontPadding * direction)
	local maxX = center.X + halfSize.X - (backPadding * direction)
	local minZ = center.Z - halfSize.Z + (sidePadding * direction)
	local maxZ = center.Z + halfSize.Z - (sidePadding * direction)

	if minX > maxX or minZ > maxZ then
		return nil
	end

	return minX, maxX, minZ, maxZ
end
GoblinService.__index = GoblinService

local function getPlayerFromHit(hit)
	if not hit then
		return nil
	end

	local model = hit:FindFirstAncestorOfClass("Model")
	if not model then
		return nil
	end

	return Players:GetPlayerFromCharacter(model)
end

function GoblinService.new(config, world, playerState)
	local self = setmetatable({}, GoblinService)
	self.config = config
	self.world = world
	self.playerState = playerState
	self.goblins = {}
	self.random = Random.new()
	return self
end

function GoblinService:start(remotes)
	self.feedbackRemote = remotes and remotes.Feedback or nil

	for index = 1, self.config.Goblins.ActiveCount do
		local spawnIndex = ((index - 1) % #self.world.goblinSpawnPoints) + 1
		self:_spawnGoblin(index, self.world.goblinSpawnPoints[spawnIndex])
	end
end

function GoblinService:_spawnGoblin(index, position)
	local model = Instance.new("Model")
	model.Name = "Goblin" .. index
	model.Parent = self.world.folders.goblins

	local root = Instance.new("Part")
	root.Name = "HumanoidRootPart"
	root.Size = Vector3.new(2.2, 2.2, 1.6)
	root.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
	root.Transparency = 1
	root.Anchored = false
	root.CanCollide = true
	root.Parent = model

	local torso = Instance.new("Part")
	torso.Name = "Torso"
	torso.Size = Vector3.new(2.8, 2.6, 1.8)
	torso.CFrame = root.CFrame + Vector3.new(0, 0.8, 0)
	torso.Anchored = false
	torso.CanCollide = false
	torso.Massless = true
	torso.Color = Color3.fromRGB(84, 120, 86)
	torso.Material = Enum.Material.SmoothPlastic
	torso.Parent = model

	local head = Instance.new("Part")
	head.Name = "Head"
	head.Shape = Enum.PartType.Ball
	head.Size = Vector3.new(1.8, 1.8, 1.8)
	head.CFrame = root.CFrame + Vector3.new(0, 2.6, 0)
	head.Anchored = false
	head.CanCollide = false
	head.Massless = true
	head.Color = Color3.fromRGB(110, 162, 98)
	head.Material = Enum.Material.SmoothPlastic
	head.Parent = model

	local weldTorso = Instance.new("WeldConstraint")
	weldTorso.Part0 = root
	weldTorso.Part1 = torso
	weldTorso.Parent = root

	local weldHead = Instance.new("WeldConstraint")
	weldHead.Part0 = root
	weldHead.Part1 = head
	weldHead.Parent = root

	local club = Instance.new("Part")
	club.Name = "Club"
	club.Size = Vector3.new(0.4, 2.2, 0.4)
	club.CFrame = root.CFrame * CFrame.new(1.2, 0.8, 0)
	club.Anchored = false
	club.CanCollide = false
	club.Massless = true
	club.Color = Color3.fromRGB(90, 66, 46)
	club.Material = Enum.Material.Wood
	club.Parent = model

	local weldClub = Instance.new("WeldConstraint")
	weldClub.Part0 = root
	weldClub.Part1 = club
	weldClub.Parent = root

	local humanoid = Instance.new("Humanoid")
	humanoid.WalkSpeed = self.config.Goblins.WalkSpeed
	humanoid.JumpPower = 0
	humanoid.AutoJumpEnabled = false
	humanoid.HipHeight = 1.6
	humanoid.Parent = model

	model.PrimaryPart = root
	model:PivotTo(CFrame.new(position + Vector3.new(0, 3, 0)))

	pcall(function()
		root:SetNetworkOwner(nil)
	end)

	local goblin = {
		model = model,
		root = root,
		humanoid = humanoid,
		home = position,
		touchCooldowns = {},
	}

	self.goblins[index] = goblin

	root.Touched:Connect(function(hit)
		self:_onTouched(index, hit)
	end)

	task.spawn(function()
		self:_runLoop(index)
	end)
end

function GoblinService:_onTouched(index, hit)
	local goblin = self.goblins[index]
	local player = goblin and getPlayerFromHit(hit)
	if not goblin or not player then
		return
	end

	local now = os.clock()
	local nextTouchAt = goblin.touchCooldowns[player] or 0
	if now < nextTouchAt then
		return
	end

	goblin.touchCooldowns[player] = now + self.config.Goblins.TouchCooldown
	self.playerState:applySlow(player, self.config.Goblins.TouchSlowDuration)

	if self.feedbackRemote then
		local playerRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		self.feedbackRemote:FireClient(player, {
			text = "Goblin hit. Slowed.",
			detail = "Back off for a moment, then re-enter when your speed recovers.",
			worldText = "Slowed",
			worldPosition = playerRoot and playerRoot.Position or goblin.root.Position,
			tone = "warn",
			intensity = "T4",
		})
	end
end

function GoblinService:_runLoop(index)
	while self.goblins[index] do
		local goblin = self.goblins[index]
		if not goblin.model.Parent then
			self.goblins[index] = nil
			break
		end

		if goblin.root.Position.Y < -20 then
			goblin.model:PivotTo(CFrame.new(goblin.home + Vector3.new(0, 3, 0)))
		end

		goblin.humanoid:MoveTo(self:_getNextDestination(goblin))
		task.wait(self.config.Goblins.RetargetInterval)
	end
end

function GoblinService:_isInsideExpandedDangerZone(position)
	local dangerZone = self.config.World
		and self.config.World.Zones
		and self.config.World.Zones.NolbuDanger
	if typeof(position) ~= "Vector3" then
		return false
	end

	local minX, maxX, minZ, maxZ = getDangerBounds(dangerZone, self.config.Goblins.ChaseZonePadding or 0, false)
	if not minX then
		return false
	end

	return position.X >= minX and position.X <= maxX and position.Z >= minZ and position.Z <= maxZ
end

function GoblinService:_getIdleRoamTarget(goblin)
	local roamOffset = Vector3.new(
		self.random:NextNumber(-self.config.Goblins.LeashRadius, self.config.Goblins.LeashRadius),
		0,
		self.random:NextNumber(-self.config.Goblins.LeashRadius, self.config.Goblins.LeashRadius)
	)
	local roamTarget = goblin.home + roamOffset

	local dangerZone = self.config.World
		and self.config.World.Zones
		and self.config.World.Zones.NolbuDanger
	local minX, maxX, minZ, maxZ = getDangerBounds(dangerZone, self.config.Goblins.IdleRoamInset or 0, true)
	if minX then
		roamTarget = Vector3.new(
			math.clamp(roamTarget.X, minX, maxX),
			roamTarget.Y,
			math.clamp(roamTarget.Z, minZ, maxZ)
		)
	end

	return Vector3.new(roamTarget.X, goblin.root.Position.Y, roamTarget.Z)
end

function GoblinService:_getNextDestination(goblin)
	local closestRoot
	local closestDistance = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		local character = player.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		local root = character and character:FindFirstChild("HumanoidRootPart")
		if humanoid and root and humanoid.Health > 0 and self:_isInsideExpandedDangerZone(root.Position) then
			local distanceFromGoblin = (root.Position - goblin.root.Position).Magnitude
			local distanceFromHome = (root.Position - goblin.home).Magnitude
			if distanceFromGoblin < closestDistance and distanceFromHome <= self.config.Goblins.ChaseRange then
				closestDistance = distanceFromGoblin
				closestRoot = root
			end
		end
	end

	if closestRoot then
		return Vector3.new(closestRoot.Position.X, goblin.root.Position.Y, closestRoot.Position.Z)
	end

	return self:_getIdleRoamTarget(goblin)
end

return GoblinService
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="9">
        <Properties>
          <string name="Name">PlayerStateService</string>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")

local PlayerStateService = {}
PlayerStateService.__index = PlayerStateService

function PlayerStateService.new(config, world)
	local self = setmetatable({}, PlayerStateService)
	self.config = config
	self.world = world
	self.playerData = {}
	self.cleanupCallbacks = {}
	return self
end

function PlayerStateService:registerCleanup(callback)
	table.insert(self.cleanupCallbacks, callback)
end

function PlayerStateService:start()
	Players.PlayerAdded:Connect(function(player)
		self:_onPlayerAdded(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self:_onPlayerRemoving(player)
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		self:_onPlayerAdded(player)
	end
end

function PlayerStateService:getData(player)
	return self.playerData[player]
end

function PlayerStateService:getSeedReward(player)
	local data = self.playerData[player]
	if not data then
		return self.config.Upgrades.Definitions.SeedMultiplier.Values[1]
	end

	return self.config.Upgrades.Definitions.SeedMultiplier.Values[data.SeedMultiplierLevel + 1]
end

function PlayerStateService:getAttackCooldown(player)
	local data = self.playerData[player]
	if not data then
		return self.config.Upgrades.Definitions.AttackSpeed.Values[1]
	end

	return self.config.Upgrades.Definitions.AttackSpeed.Values[data.AttackSpeedLevel + 1]
end

function PlayerStateService:addSeeds(player, amount)
	local data = self.playerData[player]
	if not data then
		return
	end

	data.Seeds += amount
	self:_syncPlayer(player)
end

function PlayerStateService:addMoney(player, amount)
	local data = self.playerData[player]
	if not data then
		return
	end

	data.Money += amount
	self:_syncPlayer(player)
end

function PlayerStateService:tryConsumeSeed(player)
	local data = self.playerData[player]
	if not data or data.Seeds <= 0 then
		return false
	end

	data.Seeds -= 1
	self:_syncPlayer(player)
	return true
end

function PlayerStateService:tryPurchaseUpgrade(player, upgradeId)
	local data = self.playerData[player]
	local definition = self.config.Upgrades.Definitions[upgradeId]
	if not data or not definition then
		return false, "invalid"
	end

	local currentLevel = data[definition.AttributeName]
	local nextLevel = currentLevel + 1
	local cost = self.config.Upgrades.Costs[nextLevel]
	if not cost then
		return false, "max"
	end

	if data.Money < cost then
		return false, "money", cost
	end

	data.Money -= cost
	data[definition.AttributeName] = nextLevel
	self:_syncPlayer(player)
	self:_applyWalkSpeed(player)
	return true, "ok", cost, nextLevel
end

function PlayerStateService:applySlow(player, duration)
	local data = self.playerData[player]
	if not data then
		return
	end

	data.SlowToken += 1
	local slowToken = data.SlowToken
	data.IsSlowed = true
	self:_syncPlayer(player)
	self:_applyWalkSpeed(player)

	task.delay(duration, function()
		local currentData = self.playerData[player]
		if not currentData or currentData.SlowToken ~= slowToken then
			return
		end

		currentData.IsSlowed = false
		self:_syncPlayer(player)
		self:_applyWalkSpeed(player)
	end)
end

function PlayerStateService:_onPlayerAdded(player)
	if self.playerData[player] then
		return
	end

	local data = {
		Seeds = 0,
		Money = 0,
		MoveSpeedLevel = 0,
		AttackSpeedLevel = 0,
		SeedMultiplierLevel = 0,
		IsSlowed = false,
		SlowToken = 0,
		Connections = {},
	}

	self.playerData[player] = data
	self:_syncPlayer(player)

	data.Connections[#data.Connections + 1] = player.CharacterAdded:Connect(function(character)
		self:_setupCharacter(player, character)
	end)

	if player.Character then
		task.defer(function()
			self:_setupCharacter(player, player.Character)
		end)
	end
end

function PlayerStateService:_onPlayerRemoving(player)
	local data = self.playerData[player]
	if not data then
		return
	end

	for _, callback in ipairs(self.cleanupCallbacks) do
		callback(player)
	end

	for _, connection in ipairs(data.Connections) do
		connection:Disconnect()
	end

	self.playerData[player] = nil
end

function PlayerStateService:_setupCharacter(player, character)
	local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 5)
	local root = character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart", 5)
	if not humanoid or not root then
		return
	end

	local spreadX = ((player.UserId % 5) - 2) * 3
	local spreadZ = (((math.floor(player.UserId / 5)) % 5) - 2) * 3
	character:PivotTo(self.world.spawnCFrame + Vector3.new(spreadX, 0, spreadZ))
	self:_applyWalkSpeed(player)
end

function PlayerStateService:_applyWalkSpeed(player)
	local data = self.playerData[player]
	local character = player.Character
	if not data or not character then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	local baseSpeed = self.config.Upgrades.Definitions.MoveSpeed.Values[data.MoveSpeedLevel + 1]
	local speed = data.IsSlowed and (baseSpeed * self.config.Goblins.TouchSlowFactor) or baseSpeed
	humanoid.WalkSpeed = speed
end

function PlayerStateService:_syncPlayer(player)
	local data = self.playerData[player]
	if not data then
		return
	end

	local attributes = self.config.Attributes.Player
	player:SetAttribute(attributes.Seeds, data.Seeds)
	player:SetAttribute(attributes.Money, data.Money)
	player:SetAttribute(attributes.MoveSpeedLevel, data.MoveSpeedLevel)
	player:SetAttribute(attributes.AttackSpeedLevel, data.AttackSpeedLevel)
	player:SetAttribute(attributes.SeedMultiplierLevel, data.SeedMultiplierLevel)
	player:SetAttribute(attributes.IsSlowed, data.IsSlowed)
end

return PlayerStateService
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="10">
        <Properties>
          <string name="Name">PumpkinService</string>
          <string name="Source"><![CDATA[local Workspace = game:GetService("Workspace")

local PumpkinService = {}
PumpkinService.__index = PumpkinService

local FALLBACK_SURFACE_OFFSET = 1.7

local function getRootPart(player)
	local character = player.Character
	if not character then
		return nil
	end

	return character:FindFirstChild("HumanoidRootPart")
end

local function createPrompt(parent, actionText, objectText, maxDistance)
	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText = actionText
	prompt.ObjectText = objectText
	prompt.MaxActivationDistance = maxDistance
	prompt.RequiresLineOfSight = false
	prompt.HoldDuration = 0
	prompt.Exclusivity = Enum.ProximityPromptExclusivity.OnePerButton
	prompt.Parent = parent
	return prompt
end

local function addAnchorPenalty(spawnPosition, anchors, preferredDistance, weight)
	if preferredDistance <= 0 or weight <= 0 then
		return 0
	end

	local penalty = 0
	for _, anchorPosition in ipairs(anchors or {}) do
		local distance = (spawnPosition - anchorPosition).Magnitude
		if distance < preferredDistance then
			penalty += ((preferredDistance - distance) / preferredDistance) * weight
		end
	end

	return penalty
end

function PumpkinService.new(config, world, playerState)
	local self = setmetatable({}, PumpkinService)
	self.config = config
	self.world = world
	self.playerState = playerState
	self.nextId = 0
	self.pumpkins = {}
	self.playerPumpkins = {}
	self.lastHitTimes = {}
	self.random = Random.new()
	return self
end

function PumpkinService:start(remotes)
	self.feedbackRemote = remotes.Feedback

	remotes.UseSeed.OnServerEvent:Connect(function(player)
		self:_useSeed(player)
	end)

	remotes.HitPumpkin.OnServerEvent:Connect(function(player, pumpkinId)
		self:_hitPumpkin(player, pumpkinId)
	end)
end

function PumpkinService:destroyPlayerPumpkins(player)
	local ownedPumpkins = self.playerPumpkins[player]
	if not ownedPumpkins then
		return
	end

	local ids = {}
	for pumpkinId in pairs(ownedPumpkins) do
		ids[#ids + 1] = pumpkinId
	end

	for _, pumpkinId in ipairs(ids) do
		self:_destroyPumpkin(pumpkinId)
	end

	self.playerPumpkins[player] = nil
	self.lastHitTimes[player] = nil
end

function PumpkinService:_useSeed(player)
	local root = getRootPart(player)
	if not root then
		return
	end

	if not self.playerState:tryConsumeSeed(player) then
		return
	end

	self.nextId += 1
	local pumpkinId = self.nextId
	local position = self:_getSpawnPosition(player, root)
	local expiresAt = Workspace:GetServerTimeNow() + self.config.Pumpkins.Lifetime

	local model = Instance.new("Model")
	model.Name = "Pumpkin" .. pumpkinId
	model.Parent = self.world.folders.pumpkins

	local rootPart = Instance.new("Part")
	rootPart.Name = "PumpkinRoot"
	rootPart.Shape = Enum.PartType.Ball
	rootPart.Size = Vector3.new(3.4, 3.4, 3.4)
	rootPart.CFrame = CFrame.new(position)
	rootPart.Anchored = true
	rootPart.CanCollide = true
	rootPart.Color = Color3.fromRGB(212, 132, 47)
	rootPart.Material = Enum.Material.SmoothPlastic
	rootPart.Parent = model

	local stem = Instance.new("Part")
	stem.Name = "Stem"
	stem.Size = Vector3.new(0.5, 1.2, 0.5)
	stem.CFrame = rootPart.CFrame + Vector3.new(0, 2, 0)
	stem.Anchored = true
	stem.CanCollide = false
	stem.Color = Color3.fromRGB(86, 126, 70)
	stem.Material = Enum.Material.Wood
	stem.Parent = model

	local leaf = Instance.new("Part")
	leaf.Name = "Leaf"
	leaf.Size = Vector3.new(1.4, 0.2, 0.9)
	leaf.CFrame = stem.CFrame * CFrame.new(0.4, 0.25, 0) * CFrame.Angles(0, 0, math.rad(24))
	leaf.Anchored = true
	leaf.CanCollide = false
	leaf.Color = Color3.fromRGB(124, 182, 92)
	leaf.Material = Enum.Material.Grass
	leaf.Parent = model

	model.PrimaryPart = rootPart
	model:SetAttribute(self.config.Attributes.Pumpkin.Owner, player.UserId)
	rootPart:SetAttribute(self.config.Attributes.Pumpkin.Owner, player.UserId)
	rootPart:SetAttribute(self.config.Attributes.Pumpkin.Health, self.config.Pumpkins.Health)
	rootPart:SetAttribute(self.config.Attributes.Pumpkin.ExpiresAt, expiresAt)
	rootPart:SetAttribute(self.config.Attributes.Interaction.Kind, "Pumpkin")
	rootPart:SetAttribute(self.config.Attributes.Interaction.EntityId, pumpkinId)
	createPrompt(rootPart, "Break", "Pumpkin", self.config.Pumpkins.PromptDistance)

	self.pumpkins[pumpkinId] = {
		id = pumpkinId,
		model = model,
		root = rootPart,
		owner = player,
	}

	self.playerPumpkins[player] = self.playerPumpkins[player] or {}
	self.playerPumpkins[player][pumpkinId] = true

	if self.feedbackRemote then
		self.feedbackRemote:FireClient(player, {
			text = "Pumpkin planted.",
			detail = string.format("Break it in %d hits before it fades for a money payout.", self.config.Pumpkins.Health),
			worldText = "Planted",
			worldPosition = rootPart.Position,
			tone = "info",
			intensity = "T1",
		})
	end

	task.delay(self.config.Pumpkins.Lifetime, function()
		if self.pumpkins[pumpkinId] then
			self:_destroyPumpkin(pumpkinId, "expired")
		end
	end)
end

function PumpkinService:_hitPumpkin(player, pumpkinId)
	local pumpkin = self.pumpkins[pumpkinId]
	local root = pumpkin and pumpkin.root
	local playerRoot = getRootPart(player)
	if not pumpkin or not root or not playerRoot or pumpkin.owner ~= player then
		return
	end

	if (playerRoot.Position - root.Position).Magnitude > self.config.Pumpkins.HitDistance then
		return
	end

	local now = os.clock()
	local lastHitAt = self.lastHitTimes[player] or 0
	if now - lastHitAt < self.playerState:getAttackCooldown(player) then
		return
	end

	self.lastHitTimes[player] = now

	local currentHealth = root:GetAttribute(self.config.Attributes.Pumpkin.Health) or self.config.Pumpkins.Health
	currentHealth -= 1
	root:SetAttribute(self.config.Attributes.Pumpkin.Health, currentHealth)

	if currentHealth <= 0 then
		self.playerState:addMoney(player, self.config.Pumpkins.Reward)
		if self.feedbackRemote then
			self.feedbackRemote:FireClient(player, {
				text = string.format("Pumpkin broken! +%d money", self.config.Pumpkins.Reward),
				detail = "Bring your money back to the plaza for upgrades, or plant again right away.",
				worldText = string.format("+%d Money", self.config.Pumpkins.Reward),
				worldPosition = root.Position,
				tone = "good",
				intensity = "T3",
			})
		end
		self:_destroyPumpkin(pumpkinId)
		return
	end

	if self.feedbackRemote then
		self.feedbackRemote:FireClient(player, {
			text = currentHealth == 1 and "Pumpkin cracked. One hit left." or string.format("Pumpkin cracked. %d hits left.", currentHealth),
			detail = currentHealth == 1 and "One more break for the money payout." or "Keep breaking to turn this planting into money.",
			worldText = currentHealth == 1 and "Final Hit" or string.format("%d Left", currentHealth),
			worldPosition = root.Position,
			tone = "info",
			intensity = "T2",
		})
	end
end

function PumpkinService:_destroyPumpkin(pumpkinId, reason)
	local pumpkin = self.pumpkins[pumpkinId]
	if not pumpkin then
		return
	end

	self.pumpkins[pumpkinId] = nil

	local ownerPumpkins = self.playerPumpkins[pumpkin.owner]
	if ownerPumpkins then
		ownerPumpkins[pumpkinId] = nil
		if not next(ownerPumpkins) then
			self.playerPumpkins[pumpkin.owner] = nil
		end
	end

	if reason == "expired" and self.feedbackRemote and pumpkin.owner and pumpkin.owner.Parent then
		self.feedbackRemote:FireClient(pumpkin.owner, {
			text = "Pumpkin faded.",
			detail = "Break planted pumpkins before they time out, or plant again when you are ready.",
			worldText = "Faded",
			worldPosition = pumpkin.root and pumpkin.root.Position or nil,
			tone = "warn",
			intensity = "T1",
		})
	end

	if pumpkin.model then
		pumpkin.model:Destroy()
	end
end

function PumpkinService:_getSpawnPosition(player, root)
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = { player.Character, self.world.folders.pumpkins }

	local overlapParams = OverlapParams.new()
	overlapParams.FilterType = Enum.RaycastFilterType.Exclude
	overlapParams.FilterDescendantsInstances = { player.Character }

	local forward = root.CFrame.LookVector
	local forwardFlat = Vector3.new(forward.X, 0, forward.Z)
	if forwardFlat.Magnitude < 0.001 then
		forwardFlat = Vector3.new(0, 0, -1)
	else
		forwardFlat = forwardFlat.Unit
	end

	local spawnRadius = self.config.Pumpkins.SpawnRadius
	local clearanceRadius = self.config.Pumpkins.ClearanceRadius or 2.6
	local spawnAttempts = self.config.Pumpkins.SpawnAttempts or 8
	local placementBias = self.config.Pumpkins.PlacementBias or {}
	local upgradePadAnchors = {}
	for _, padDef in pairs(self.config.World.UpgradePads or {}) do
		if typeof(padDef.position) == "Vector3" then
			table.insert(upgradePadAnchors, padDef.position)
		end
	end
	local swallowAnchors = self.world.swallowSpawnPoints or self.config.World.SwallowSpawnPoints or {}
	local dangerRockAnchors = self.config.World.DangerRockPositions or {}
	local bestPosition
	local bestPenalty = math.huge

	for attempt = 1, spawnAttempts do
		local angleOffset = self.random:NextNumber(-math.pi * 0.85, math.pi * 0.85)
		local distanceScale = self.random:NextNumber(0.68, 1)
		local offsetDirection = CFrame.fromAxisAngle(Vector3.yAxis, angleOffset):VectorToWorldSpace(forwardFlat)
		local targetPosition = root.Position + (offsetDirection * spawnRadius * distanceScale)
		local origin = targetPosition + Vector3.new(0, self.config.Pumpkins.SpawnHeight, 0)
		local result = Workspace:Raycast(origin, Vector3.new(0, -self.config.Pumpkins.SpawnHeight * 2, 0), rayParams)
		local groundPosition = result and result.Position or Vector3.new(targetPosition.X, root.Position.Y - 3, targetPosition.Z)
		local spawnPosition = Vector3.new(targetPosition.X, groundPosition.Y + FALLBACK_SURFACE_OFFSET, targetPosition.Z)
		local overlapParts = Workspace:GetPartBoundsInRadius(spawnPosition, clearanceRadius, overlapParams)

		local penalty = 0
		for _, part in ipairs(overlapParts) do
			if part:IsDescendantOf(self.world.folders.pumpkins) then
				penalty += 100
			elseif part.CanCollide and not part:IsDescendantOf(player.Character) then
				penalty += 1
			end
		end

		penalty += addAnchorPenalty(
			spawnPosition,
			upgradePadAnchors,
			placementBias.UpgradePadDistance or 0,
			placementBias.UpgradePadWeight or 0
		)
		penalty += addAnchorPenalty(
			spawnPosition,
			swallowAnchors,
			placementBias.SwallowDistance or 0,
			placementBias.SwallowWeight or 0
		)
		penalty += addAnchorPenalty(
			spawnPosition,
			dangerRockAnchors,
			placementBias.DangerRockDistance or 0,
			placementBias.DangerRockWeight or 0
		)

		if penalty <= 0 then
			return spawnPosition
		end

		if penalty < bestPenalty then
			bestPenalty = penalty
			bestPosition = spawnPosition
		end
	end

	if bestPosition then
		return bestPosition
	end

	local fallbackTarget = root.Position + (forwardFlat * spawnRadius)
	return Vector3.new(fallbackTarget.X, root.Position.Y - 1.3, fallbackTarget.Z)
end

return PumpkinService
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="11">
        <Properties>
          <string name="Name">SwallowService</string>
          <string name="Source"><![CDATA[local SwallowService = {}
SwallowService.__index = SwallowService

local function getRootPart(player)
	local character = player.Character
	if not character then
		return nil
	end

	return character:FindFirstChild("HumanoidRootPart")
end

local function createPrompt(parent, actionText, objectText, maxDistance)
	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText = actionText
	prompt.ObjectText = objectText
	prompt.MaxActivationDistance = maxDistance
	prompt.RequiresLineOfSight = false
	prompt.HoldDuration = 0
	prompt.Exclusivity = Enum.ProximityPromptExclusivity.OnePerButton
	prompt.Parent = parent
	return prompt
end

function SwallowService.new(config, world, playerState)
	local self = setmetatable({}, SwallowService)
	self.config = config
	self.world = world
	self.playerState = playerState
	self.nextId = 0
	self.spawnCursor = 0
	self.swallows = {}
	self.occupiedSpawnIndices = {}
	self.random = Random.new()
	return self
end

function SwallowService:start(remotes)
	self.feedbackRemote = remotes.Feedback

	remotes.HealSwallow.OnServerEvent:Connect(function(player, swallowId)
		self:_healSwallow(player, swallowId)
	end)

	for _ = 1, self.config.Swallows.ActiveCount do
		self:_spawnSwallow()
	end
end

function SwallowService:_healSwallow(player, swallowId)
	local swallow = self.swallows[swallowId]
	local root = swallow and swallow.root
	local playerRoot = getRootPart(player)
	if not swallow or not root or not playerRoot then
		return
	end

	if (playerRoot.Position - root.Position).Magnitude > self.config.Swallows.HealDistance then
		return
	end

	local reward = self.playerState:getSeedReward(player)
	self.playerState:addSeeds(player, reward)

	if self.feedbackRemote then
		self.feedbackRemote:FireClient(player, {
			text = string.format("Swallow healed. +%d seed%s gained.", reward, reward == 1 and "" or "s"),
			detail = reward > 1 and "Blessing paid out extra seeds for your next planting run." or "Plant a pumpkin anywhere to turn that seed into coins.",
			worldText = string.format("+%d Seed%s", reward, reward == 1 and "" or "s"),
			worldPosition = root.Position,
			tone = "good",
			intensity = "T2",
		})
	end

	self:_destroySwallow(swallowId)
	self:_maintainSwallows()
end

function SwallowService:_maintainSwallows()
	while self:_activeCount() < self.config.Swallows.ActiveCount do
		self:_spawnSwallow()
	end
end

function SwallowService:_activeCount()
	local count = 0
	for _ in pairs(self.swallows) do
		count += 1
	end
	return count
end

function SwallowService:_spawnSwallow()
	local spawnIndex = self:_takeOpenSpawnIndex()
	if not spawnIndex then
		return
	end

	self.nextId += 1
	local swallowId = self.nextId
	local position = self.world.swallowSpawnPoints[spawnIndex]

	local model = Instance.new("Model")
	model.Name = "Swallow" .. swallowId
	model.Parent = self.world.folders.swallows

	local nest = Instance.new("Part")
	nest.Name = "Nest"
	nest.Shape = Enum.PartType.Cylinder
	nest.Size = Vector3.new(2.2, 0.35, 2.2)
	nest.CFrame = CFrame.new(position + Vector3.new(0, -1.15, 0)) * CFrame.Angles(0, 0, math.rad(90))
	nest.Anchored = true
	nest.CanCollide = false
	nest.Color = Color3.fromRGB(112, 83, 56)
	nest.Material = Enum.Material.WoodPlanks
	nest.Parent = model

	local root = Instance.new("Part")
	root.Name = "SwallowRoot"
	root.Size = Vector3.new(1.7, 0.9, 2.1)
	root.CFrame = CFrame.new(position) * CFrame.Angles(0, math.rad(self.random:NextInteger(-30, 30)), math.rad(14))
	root.Anchored = true
	root.CanCollide = false
	root.Color = Color3.fromRGB(56, 58, 67)
	root.Material = Enum.Material.SmoothPlastic
	root.Parent = model

	local wing = Instance.new("Part")
	wing.Name = "Wing"
	wing.Size = Vector3.new(2.3, 0.2, 0.95)
	wing.CFrame = root.CFrame * CFrame.new(0, 0.2, 0.15) * CFrame.Angles(0, 0, math.rad(-18))
	wing.Anchored = true
	wing.CanCollide = false
	wing.Color = Color3.fromRGB(220, 224, 235)
	wing.Material = Enum.Material.SmoothPlastic
	wing.Parent = model

	root:SetAttribute(self.config.Attributes.Interaction.Kind, "Swallow")
	root:SetAttribute(self.config.Attributes.Interaction.EntityId, swallowId)
	createPrompt(root, "Heal", "Injured Swallow", self.config.Swallows.PromptDistance)

	self.swallows[swallowId] = {
		model = model,
		root = root,
		spawnIndex = spawnIndex,
	}
end

function SwallowService:_destroySwallow(swallowId)
	local swallow = self.swallows[swallowId]
	if not swallow then
		return
	end

	self.occupiedSpawnIndices[swallow.spawnIndex] = nil
	self.swallows[swallowId] = nil

	if swallow.model then
		swallow.model:Destroy()
	end
end

function SwallowService:_takeOpenSpawnIndex()
	local totalSpawns = #self.world.swallowSpawnPoints
	if totalSpawns == 0 then
		return nil
	end

	for step = 1, totalSpawns do
		local index = ((self.spawnCursor + step - 1) % totalSpawns) + 1
		if not self.occupiedSpawnIndices[index] then
			self.spawnCursor = index
			self.occupiedSpawnIndices[index] = true
			return index
		end
	end

	return nil
end

return SwallowService
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="12">
        <Properties>
          <string name="Name">UpgradeService</string>
          <string name="Source"><![CDATA[local UpgradeService = {}
UpgradeService.__index = UpgradeService

local PURCHASE_DETAILS = {
	MoveSpeed = "Your next route should feel lighter immediately.",
	AttackSpeed = "Your next pumpkin should cash out faster.",
	SeedMultiplier = "Your next swallow heal should feed a bigger loop.",
}

function UpgradeService.new(config, world, playerState)
	local self = setmetatable({}, UpgradeService)
	self.config = config
	self.world = world
	self.playerState = playerState
	return self
end

function UpgradeService:start(remotes)
	self.feedbackRemote = remotes and remotes.Feedback or nil

	for upgradeId, prompt in pairs(self.world.upgradePrompts) do
		prompt.Triggered:Connect(function(player)
			local success, reason, cost, newLevel = self.playerState:tryPurchaseUpgrade(player, upgradeId)
			if not self.feedbackRemote then
				return
			end

			local definition = self.config.Upgrades.Definitions[upgradeId]
			local displayName = definition.DisplayName
			local purchaseDetail = PURCHASE_DETAILS[upgradeId] or "Your next loop should feel better right away."
			local promptParent = prompt.Parent
			local promptPosition = promptParent and promptParent:IsA("BasePart") and promptParent.Position or nil
			if success then
				self.feedbackRemote:FireClient(player, {
					text = string.format("Bought %s Lv.%d (-%d money)", displayName, newLevel, cost),
					detail = purchaseDetail,
					worldText = string.format("%s Up", displayName),
					worldPosition = promptPosition,
					tone = "good",
					intensity = "T3",
					context = "UpgradePurchase",
					upgradeId = upgradeId,
				})
			elseif reason == "money" then
				self.feedbackRemote:FireClient(player, {
					text = string.format("Need %d money for %s", cost, displayName),
					detail = "Break another pumpkin or two, then come back to the plaza.",
					worldText = string.format("Need %d", cost),
					worldPosition = promptPosition,
					tone = "warn",
					intensity = "T1",
				})
			elseif reason == "max" then
				self.feedbackRemote:FireClient(player, {
					text = string.format("%s is maxed", displayName),
					detail = "Buy a different upgrade or keep the loop moving.",
					worldText = "MAX",
					worldPosition = promptPosition,
					tone = "warn",
					intensity = "T1",
				})
			end
		end)
	end
end

return UpgradeService
]]></string>
        </Properties>
      </Item>
    </Item>

				title = "Nolbu Area",
				body = "Watch for slowing goblins.",
			},
		},
		Paths = {
			{
				name = "VillagePathA",
				size = Vector3.new(48, 1, 12),
				cframe = CFrame.new(-35, 0.45, 22) * CFrame.Angles(0, math.rad(8), 0),
				color = Color3.fromRGB(138, 114, 84),
			},
			{
